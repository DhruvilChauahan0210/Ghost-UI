{
  "name": "@ghost-ui/core",
  "version": "0.1.0",
  "description": "Framework-agnostic core for Ghost UI — observer, optimizer, persistence.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts src/worker.ts --format esm --dts --clean --sourcemap",
    "dev": "tsup src/index.ts src/worker.ts --format esm --dts --watch --sourcemap",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "comlink": "^4.4.2"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
