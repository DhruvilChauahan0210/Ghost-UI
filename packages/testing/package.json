{
  "name": "@ghost-ui/testing",
  "version": "0.1.0",
  "description": "Testing utilities for Ghost UI — engine helpers, custom matchers, React render wrapper.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts src/react.tsx --format esm --dts --clean --sourcemap --external react --external react-dom --external @testing-library/react",
    "dev": "tsup src/index.ts src/react.tsx --format esm --dts --watch --sourcemap --external react --external react-dom --external @testing-library/react",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ghost-ui/core": "workspace:*",
    "@ghost-ui/react": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0",
    "@testing-library/react": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true },
    "@testing-library/react": { "optional": true }
  },
  "devDependencies": {
    "@ghost-ui/react": "workspace:*",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
